# Firebase client config (web app)
# NOTE: VITE_ variables are exposed to the browser by design.
# NEVER put Firebase service-account credentials in VITE_ env vars.
# For production, configure these in Vercel Project Settings -> Environment Variables.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=sviwa-creation.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sviwa-creation
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloudinary image upload config
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# Public contact/social config
VITE_WHATSAPP_NUMBER=
VITE_INSTAGRAM_URL=

# Legacy CSV fallback only if still used
VITE_PRODUCT_CSV_URL=

# Optional non-Firebase app envs used elsewhere in this app
APP_URL=
GEMINI_API_KEY=
