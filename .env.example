# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where this app is hosted.
APP_URL="MY_APP_URL"

# CSV source used for exhibition display mode.
# Shopify export format expected.
VITE_PRODUCT_CSV_URL="/products.csv"

# Cloudinary Configuration (Required for Admin image uploads)
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""

# Social & Contact (Recommended for launch)
# Use international format without '+' e.g. 919876543210
VITE_WHATSAPP_NUMBER=""
VITE_INSTAGRAM_URL=""
